// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  phone        String?
  address      String?
  bio          String?
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store               Store?
  accounts            Account[]
  notificationSettings NotificationSettings?
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model NotificationSettings {
  id                   String  @id @default(cuid())
  userId               String  @unique
  emailNotification    Boolean @default(true)
  whatsappNotification Boolean @default(true)
  aiInsight            Boolean @default(true)
  lowStock             Boolean @default(true)
  dailyBrief           Boolean @default(true)
  marketingReminder    Boolean @default(true)
  weeklyReport         Boolean @default(true)
  monthlyReport        Boolean @default(true)
  campaignReminder     Boolean @default(true)
  broadcastReminder    Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Account {
  id                String @id @default(cuid())
  userId            String
  provider          String // "google", "credentials"
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

// ─────────────────────────────────────────
// STORE
// ─────────────────────────────────────────

model Store {
  id                  String   @id @default(cuid())
  userId              String   @unique
  name                String
  currency            String   @default("IDR")
  timezone            String   @default("Asia/Jakarta")
  address             String?
  city                String?
  province            String?
  postalCode          String?
  phone               String?
  whatsapp            String?
  logoUrl             String?
  businessCategory    String?
  description         String?
  website             String?
  operatingHours      String?
  googleMapsLink      String?
  npwp                String?
  instagram           String?
  facebook            String?
  tiktok              String?
  waBusinessPhoneId   String?
  waBusinessAccountId String?
  waBusinessApiKey    String?
  waBusinessVerifyToken String?
  waBusinessWebhookUrl String?
  emailSmtpHost       String?
  emailSmtpPort       Int?
  emailSmtpUser       String?
  emailSmtpPassword   String?
  emailEncryption     String?
  emailSenderName     String?
  emailSenderEmail    String?
  instagramAccessToken String?
  instagramBusinessAccount String?
  facebookPageId      String?
  facebookAccessToken String?
  geminiApiKey        String?
  geminiModel         String? @default("gemini-2.0-flash")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories      Category[]
  products        Product[]
  customers       Customer[]
  orders          Order[]
  campaigns       Campaign[]
  broadcasts      Broadcast[]
  agendaItems     AgendaItem[]
  aiInsights      AiInsight[]
  aiConversations AiConversation[]
  notifications   Notification[]

  @@map("stores")
}

// ─────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  storeId   String
  name      String // "Minuman", "Makanan", "Snack"
  color     String? // hex color untuk badge, e.g. "#6D5DF6"
  createdAt DateTime @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, name])
  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  categoryId  String
  sku         String
  name        String
  description String?
  price       Int // harga jual (rupiah)
  costPrice   Int? // harga modal — untuk kalkulasi margin oleh AI
  imageUrl    String?
  isActive    Boolean  @default(true)
  aiScore     Int? // 0–100, di-generate oleh AI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store      Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category       @relation(fields: [categoryId], references: [id])
  inventory  InventoryItem?
  orderItems OrderItem[]

  @@unique([storeId, sku])
  @@map("products")
}

// ─────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────

model InventoryItem {
  id              String      @id @default(cuid())
  productId       String      @unique
  sku             String
  currentStock    Int         @default(0)
  minStock        Int         @default(0)
  unit            String // "kg", "liter", "pcs"
  status          StockStatus @default(NORMAL)
  lastRestockedAt DateTime? // untuk AI: "Sudah 45 hari belum restock"
  updatedAt       DateTime    @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@map("inventory_items")
}

model StockMovement {
  id              String       @id @default(cuid())
  inventoryItemId String
  type            MovementType // IN, OUT, ADJUSTMENT
  quantity        Int
  note            String?
  createdAt       DateTime     @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

enum StockStatus {
  NORMAL
  LOW // currentStock < minStock
  EMPTY // currentStock = 0
}

enum MovementType {
  IN // restock
  OUT // terjual / terpakai
  ADJUSTMENT // koreksi manual
}

// ─────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────

model Customer {
  id          String       @id @default(cuid())
  storeId     String
  name        String
  email       String?
  phone       String?
  tier        CustomerTier @default(BRONZE)
  optInWhatsApp Boolean    @default(true)
  optInEmail    Boolean    @default(true)
  lastOrderAt DateTime? // denormalized — untuk dashboard & AI query cepat
  totalSpent  Int          @default(0) // denormalized — rupiah
  joinedAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([storeId, email])
  @@map("customers")
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ─────────────────────────────────────────
// ORDERS / SALES
// ─────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  storeId       String
  customerId    String?
  orderNumber   String
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH)
  subtotal      Int // rupiah
  discount      Int           @default(0)
  total         Int
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  store    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id])
  items    OrderItem[]

  @@unique([storeId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int // harga saat transaksi (snapshot, bukan referensi)
  subtotal  Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
}

// ─────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────

model Campaign {
  id               String         @id @default(cuid())
  storeId          String
  name             String
  objective        String?
  description      String?
  targetCustomer   String?
  promotionType    String?
  promotionValue   Int?
  startDate        DateTime?
  endDate          DateTime?
  status           CampaignStatus @default(DRAFT)
  aiGenerated      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  broadcasts Broadcast[]

  @@map("campaigns")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  FINISHED
}

// ─────────────────────────────────────────
// BROADCASTS
// ─────────────────────────────────────────

model Broadcast {
  id               String           @id @default(cuid())
  storeId          String
  campaignId       String?
  title            String
  channel          BroadcastChannel // WHATSAPP, EMAIL, SMS
  status           BroadcastStatus  @default(DRAFT)
  content          String // isi pesan
  targetCustomer   String?
  totalTarget      Int              @default(0)
  successCount     Int              @default(0)
  failedCount      Int              @default(0)
  pendingCount     Int              @default(0)
  deliveredCount   Int              @default(0)
  readCount        Int              @default(0)
  clickCount       Int              @default(0)
  scheduledAt      DateTime?
  sentAt           DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("broadcasts")
}

enum BroadcastChannel {
  WHATSAPP
  EMAIL
  SMS
  INSTAGRAM
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENT
}

// ─────────────────────────────────────────
// DAILY BRIEF — AGENDA
// ─────────────────────────────────────────

model AgendaItem {
  id        String   @id @default(cuid())
  storeId   String
  time      String // "09:00"
  title     String
  tag       String? // "Inventory", "Produk", dll
  date      DateTime
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("agenda_items")
}

// ─────────────────────────────────────────
// AI INSIGHTS (cache hasil generate AI)
// ─────────────────────────────────────────

model AiInsight {
  id          String      @id @default(cuid())
  storeId     String
  type        InsightType
  content     Json // pakai Json — tidak perlu serialize/deserialize manual
  generatedAt DateTime    @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, type])
  @@map("ai_insights")
}

enum InsightType {
  DAILY_BRIEF
  CUSTOMER
  PRODUCT
  INVENTORY
  CAMPAIGN
  ANALYTICS
}

// ─────────────────────────────────────────
// AI CONVERSATION HISTORY
// ─────────────────────────────────────────

model AiConversation {
  id        String           @id @default(cuid())
  storeId   String
  role      ConversationRole // USER, ASSISTANT
  content   String
  createdAt DateTime         @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@map("ai_conversations")
}

enum ConversationRole {
  USER
  ASSISTANT
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  storeId   String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isRead])
  @@map("notifications")
}

enum NotificationType {
  STOCK_LOW // stok hampir habis
  CAMPAIGN_ENDED // campaign selesai
  NEW_ORDER // order baru masuk
  AI_COMPLETE // AI selesai generate insight
}
